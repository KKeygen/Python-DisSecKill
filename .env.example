# 环境变量配置（复制为 .env 并填写实际值）

# MySQL
MYSQL_ROOT_PASSWORD=disseckill_root_2026
MYSQL_DATABASE=disseckill
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092

# Nacos
NACOS_ENABLED=true
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_CONFIG_DATA_ID=gateway-config.json
NACOS_CONFIG_REFRESH_SEC=5

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
